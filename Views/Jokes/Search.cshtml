@{
    ViewData["Title"] = "Search Jokes";
}

<h2>Search Jokes</h2>

<p>Type a keyword to find jokes:</p>

<form asp-action="SearchResults" method="get">
    <input type="text" name="query" placeholder="Search jokes..." />
    <button type="submit">Search</button>
</form>